# LeetCode Configuration
LEETCODE_USERNAME=your_leetcode_username

# Email — Option 1: Resend HTTP API (recommended for Railway/cloud)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=LeetCode Planner <onboarding@resend.dev>

# Email — Option 2: SMTP (works locally or on platforms that allow SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email recipient
EMAIL_TO=recipient@gmail.com

# Planner Settings
DAILY_PROBLEMS=4

# Cloud Settings
CRON_SECRET=change_me_in_production

# Database
DATABASE_URL=sqlite:///./leetcode_planner.db
